# Food Delivery Pipeline — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Database
DATABASE_NAME=food_delivery.db

# Scraper
# Set to "True" to use mock data instead of live scraping
SCRAPER_USE_MOCK=False
# Custom user agent for the scraper
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
# Locale for price parsing ("auto", "eu", "us")
SCRAPER_LOCALE=auto
# Delay between scrape requests in seconds
SCRAPER_RATE_LIMIT_DELAY=3
# Max retries per URL
SCRAPER_MAX_RETRIES=3
# Base delay for retry backoff in seconds
SCRAPER_RETRY_BASE_DELAY=5
# Navigation timeout in milliseconds
SCRAPER_NAVIGATION_TIMEOUT=60000
# Max redirects before aborting
SCRAPER_MAX_REDIRECTS=5

# Entity Resolution Engine
ER_WEIGHT_NAME=0.6
ER_WEIGHT_GEO=0.4
ER_LAMBDA_GEO=0.00035
ER_DEFAULT_THRESHOLD=0.70
# Comma-separated list of known cities for geographic blocking
KNOWN_CITIES=Barcelona,Madrid,Valencia,London,Paris,Berlin,Rome

# Text Classifier
CLASSIFIER_MODEL_NAME=all-MiniLM-L6-v2
CLASSIFIER_CONFIDENCE_THRESHOLD=0.5

# Image Processor
IMAGE_BATCH_SIZE=10
IMAGE_MAX_BATCH_SIZE=32
IMAGE_MIN_WIDTH=50
IMAGE_MIN_HEIGHT=50
# Comma-separated list of food categories (fallback if taxonomy DB unavailable)
FOOD_CATEGORIES=pizza,burger,sushi,pasta,salad,sandwich,taco

# API
API_HOST=localhost
API_PORT=8000
# Comma-separated list of allowed CORS origins
API_CORS_ORIGINS=http://localhost:8000
